[colors]
background = #191e23
background-alt = #373B41
foreground = #a43838
primary = #a43838
secondary = #ff8d99

[bar/bar]
monitor=${env:MONITOR:}
width = 100%
height = 24pt
radius = 6

; dpi = 96

background = ${colors.background}
foreground = ${colors.foreground}

line-size = 3pt

border-size = 4pt
border-color = #00000000

padding-left = 0
padding-right = 1

module-margin = 1

separator = |
separator-foreground = ${colors.primary}

font-0 = "DroidSansMono Nerd Font:style=Regular:size=12;2"
font-1 = "DroidSansMono Nerd Font:style=Regular:size=12;2"

modules-left = i3 
modules-center = date 
modules-right = wireless-network pulseaudio memory cpu battery
cursor-click = pointer
cursor-scroll = ns-resize

enable-ipc = true

; tray-position = right

; wm-restack = generic
; wm-restack = bspwm
; wm-restack = i3

; override-redirect = true



[module/i3]
type = internal/i3

pin-workspaces = true
show-urgent = true
enable-scroll = false

format = <label-state> <label-mode>

label-mode = %mode%
label-mode-padding = 2
label-mode-background = #cc241d

label-focused = %index%
label-focused-foreground = ${colors.foreground}
label-focused-background = ${colors.secondary}
label-focused-underline = ${colors.primary}
label-focused-padding = 4

label-unfocused = %index%
label-unfocused-padding = 4

label-visible = %index%
label-visible-underline = #555555
label-visible-padding = 4

label-urgent = %index%
label-urgent-foreground = #000000
label-urgent-background = #bd2c40
label-urgent-padding = 4

label-separator = |
label-separator-padding = 2
label-separator-foreground = ${colors.primary} 

[module/xwindow]
type = internal/xwindow
label = %title:0:60:...%

[module/pulseaudio]
type = internal/pulseaudio

format-volume-prefix = "ůįēĺ "
format-volume-foreground = ${colors.secondary}
format-volume-prefix-foreground = ${colors.primary}
format-volume = <label-volume>

label-active-font = 1
label-volume = %percentage%%

label-muted = "muted"
label-muted-foreground = ${colors.secondary}
click-right = pavucontrol

[module/memory]
type = internal/memory
interval = 2
format-prefix = "ůįćõ " 
format-prefix-foreground = ${colors.primary}

label = %percentage_used:2%%
label-foreground = ${colors.secondary}

[module/cpu]
type = internal/cpu
interval = 2
format-prefix = "ůį®£ "
format-prefix-foreground = ${colors.primary}

label = %percentage:2%%
label-foreground = ${colors.secondary}

[module/date]
type = custom/script

format-prefix = "ÔĀ≥  "  
exec = date +'%d/%m/%Y - %H:%M'
tail = false
interval = 5

format-foreground = ${colors.secondary}
format-prefix-foreground = ${colors.primary}
click-right = ticktick

[module/wlan]
type = internal/network
interface = wlp0s20f3

interface-type = wireless

label-connected = %essid% %upspeed%
format-packetloss = <animation-packetloss> <label-connected>

[module/battery]
type = internal/battery

full-at = 99

low-at = 10

battery = BAT1
adapter = ACAD

time-format = %H-%M
label-full-foreground = ${colors.secondary}

format-charging = <animation-charging> <label-charging> 
format-discharging = <ramp-capacity> <label-discharging> 
format-full = <ramp-capacity> <label-full>

label-charging = %percentage%
label-discharging = %percentage%
label-full = %percentage%%
label-low = %percentage%

ramp-capacity-0 = ÔČĄ
ramp-capacity-1 = ÔČÉ
ramp-capacity-2 = ÔČā
ramp-capacity-3 = ÔČĀ
ramp-capacity-4 = ÔČÄ

animation-charging-0 = ÔČĄ
animation-charging-1 = ÔČÉ
animation-charging-2 = ÔČā
animation-charging-3 = ÔČĀ
animation-charging-4 = ÔČÄ
animation-charging-framerate = 750

animation-discharging-0 = ÔČÄ
animation-discharging-1 = ÔČĀ
animation-discharging-2 = ÔČā
animation-discharging-3 = ÔČÉ
animation-discharging-4 = ÔČĄ
animation-discharging-framerate = 500

animation-low-0 = !
animation-low-1 = 
animation-low-framerate = 200

[settings]
screenchange-reload = true
pseudo-transparency = true

; vim:ft=dosini
